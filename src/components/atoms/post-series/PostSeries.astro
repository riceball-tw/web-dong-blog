---
import type { CollectionEntry } from "astro:content";
import { getRelativeLocaleUrl } from "astro:i18n";
import { Icon } from "astro-icon/components";
import Accordion from "@/components/atoms/accordion/Accordion.astro";
import { useTranslations, getLocale } from "@/i18n/i18n";
import {
	defaultLocale,
	getLanguageCode,
	type LanguageKey,
	stripLanguageCode,
} from "@/utils/i18n.ts";

export interface Props {
	currentLocale: LanguageKey;
	currentPost: CollectionEntry<"post">;
	postsInSeries: CollectionEntry<"post">[];
}
const t = useTranslations(getLocale(Astro.currentLocale));
const { currentPost, postsInSeries, currentLocale } = Astro.props;
const currentLocalePostsInSeries = postsInSeries.reduce(
	(total: CollectionEntry<"post">[], curr) => {
		if (getLanguageCode(curr.id) === currentLocale) {
			return [...total, curr];
		}
		return total;
	},
	[],
);
---

<div data-cy="series-summary" data-pagefind-ignore="all">


<Accordion iconName="material-symbols:import-contacts-outline-rounded" isOpened={false} summary={`${currentPost.data.series} ${t("stale_level_platypus_savor")}`}>
  <ul class='pb-4'>
  {currentLocalePostsInSeries.map(({data, id}) => {
   const isCurrentPost = currentPost.id === id
   return (
      <li>
        <a class={`inline-flex items-center gap-2 p-2 px-4 transition-opacity hover:underline no-underline hover:opacity-100 ${isCurrentPost ? 'opacity-100 text-primary' : 'opacity-40'}`} 
        href={getRelativeLocaleUrl(Astro.currentLocale || defaultLocale, `/post/${stripLanguageCode(id)}/`)}>
        {isCurrentPost && <span>
          <Icon size={24}  name="material-symbols:arrow-right-alt-rounded" />
        </span>}
          <span data-cy={`${isCurrentPost ? "series-active" : ''}`}>{data.headline}</span>
        </a>
      </li>
    )
  })}
  </ul>
  </Accordion>
</div>
