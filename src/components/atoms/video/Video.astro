---
import { getLocale, useTranslations } from "@/i18n/i18n";

export interface Props {
	width: number;
	height: number;
	data: Array<{
		src: string;
		type: string;
	}>;
}

const t = useTranslations(getLocale(Astro.currentLocale));
const { width, height, data } = Astro.props;
---

<video class="col-span-full mx-auto z-10" width={width} height={height} autoplay muted playsinline loop>
  {
    data.map((source: { src: string; type: string }) => (
      <source src={source.src.startsWith('http') ? source.src : import.meta.env.BASE_URL + source.src} type={`video/${source.type}`} />
    ))
  }
  <p>{t("sharp_best_swan_accept")}</p>
</video>
