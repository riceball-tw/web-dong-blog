---
import { render } from "astro:content";
import MarkdownIt from "markdown-it";
import Container from "@/components/atoms/container/Container.astro";
import PostImage from "@/components/atoms/post-image/PostImage.astro";
import ShortpostList from "@/components/atoms/shortpost-list/ShortpostList.astro";
import BlogBase from "@/layouts/BlogBase.astro";
import { dateSortedLocaleRelatedShortposts } from "@/utils/getShortposts.ts";
import { getLocale } from "@/i18n/i18n";
import {
	languages,
	stripLanguageCode,
} from "@/utils/i18n.ts";

export async function getStaticPaths() {
	return Object.keys(languages).flatMap((language) =>
		dateSortedLocaleRelatedShortposts(getLocale(language)).map(
			(shortpost) => ({
				params: { slug: stripLanguageCode(shortpost.id), language },
				props: {
					shortpost,
					shortposts: dateSortedLocaleRelatedShortposts(
						getLocale(language),
					),
				},
			}),
		),
	);
}

const { shortpost, shortposts } = Astro.props;
const { headline } = shortpost.data;
const { Content } = await render(shortpost);
const leaveSpaceforLastShortStyle = `padding-bottom: 20vh`;
// How to Create Excerpts With Astro
// https://www.paulie.dev/posts/2023/09/how-to-create-excerpts-with-astro/#creating-the-substring
const markdownParser = new MarkdownIt();
const createExcerpt = (body: string, maxLength: number = 160) =>
	markdownParser
		.render(body)
		.split("\n")
		.slice(0, 6)
		.flatMap((str: string) => str.replace(/<\/?[^>]+(>|$)/g, "").split("\n"))
		.join(" ")
		.substring(0, maxLength);
const excerpt = createExcerpt(shortpost.body || "");
---
<BlogBase title={headline} description={excerpt} thumbnail={{ src: `/og/shortpost/${Astro.currentLocale}/${stripLanguageCode(shortpost.id)}.png`, alt: headline, width: 1200, height: 630 }}>
  <Container>
    <main style={leaveSpaceforLastShortStyle} class="mt-0 pt-8 px-6 sm:mt-[var(--mainNav-height)]">
      <ShortpostList shortposts={shortposts} currentSlug={shortpost.id}>
        <Content components={{ img: PostImage }}  />
      </ShortpostList>
    </main>
  </Container>
</BlogBase>
